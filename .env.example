# Resend (contact form email delivery) — https://resend.com
RESEND_API_KEY=
# Must be an address on a domain you've verified in Resend, e.g. "Yehia.Makes <hello@yehiamakes.com>"
# For testing before you verify a domain, you can use "onboarding@resend.dev"
RESEND_FROM_EMAIL=
# Where project briefs land
CONTACT_TO_EMAIL=ymohamedelmohamady@gmail.com

# Cal.com (real availability + booking for the schedule panel) — https://cal.com
# Personal access token, from Settings > Developer > API Keys
CAL_API_KEY=
# Your Cal.com username and the slug of the 30-min event type, from
# https://cal.com/<username>/<slug> (e.g. cal.com/jdoe/30min -> CAL_USERNAME=jdoe, CAL_EVENT_SLUG=30min)
CAL_USERNAME=
CAL_EVENT_SLUG=
# Timezone slots are displayed/booked in
CAL_TIMEZONE=Africa/Cairo
